<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.lotoanalyzer.frontend.controller.MainController" styleClass="root-pane">
    <top>
        <VBox spacing="10" styleClass="header-box" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16" right="20" bottom="14" left="20"/>
            </padding>
            <Label text="LotoAnalyzer" styleClass="title"/>
            <Label text="Análise estatística inteligente da Lotofácil" styleClass="subtitle"/>
            <HBox spacing="10">
                <Label text="API Base" styleClass="field-label"/>
                <TextField fx:id="apiBaseUrlField" prefWidth="500"/>
                <Label fx:id="statusLabel" styleClass="status-chip" text="Status"/>
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox spacing="10" styleClass="menu-box">
            <padding>
                <Insets top="20" right="16" bottom="20" left="16"/>
            </padding>
            <Button fx:id="importarButton" text="Importar histórico" onAction="#onImportarHistorico" styleClass="menu-button"/>
            <Button fx:id="estatisticasButton" text="Ver estatísticas" onAction="#onVerEstatisticas" styleClass="menu-button"/>
            <Button fx:id="tendenciasButton" text="Ver tendências" onAction="#onVerTendencias" styleClass="menu-button"/>
            <Button fx:id="jogosButton" text="Gerar jogos" onAction="#onGerarJogos" styleClass="menu-button menu-primary"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="8" styleClass="content-box">
            <padding>
                <Insets top="20" right="20" bottom="20" left="10"/>
            </padding>
            <Label text="Saída" styleClass="section-title"/>
            <TextArea fx:id="outputArea" wrapText="true" styleClass="output-area" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
